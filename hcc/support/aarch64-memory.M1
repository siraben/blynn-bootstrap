## hcc AArch64 bump allocator for bootstrap links.

DEFINE HCC_A64_SET_X0_FROM_X16 e00310aa
DEFINE HCC_A64_SET_X1_FROM_X16 e10310aa
DEFINE HCC_A64_STR_X0_X16 000200f9
DEFINE HCC_A64_MOV_X0_X1 e00301aa
DEFINE HCC_A64_POP_X2 428640f8

:FUNCTION_malloc
	SET_X1_FROM_X0
	PUSH_X1
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&hcc_support_brk
	HCC_A64_SET_X0_FROM_X16
	DEREF_X0
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&HCC_MEM_MALLOC_INIT
	CBNZ_X0_PAST_BR
	BR_X16
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&HCC_MEM_MALLOC_READY
	BR_X16
:HCC_MEM_MALLOC_INIT
	SET_X0_TO_0
	SET_X8_TO_SYS_BRK
	SYSCALL
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&hcc_support_brk
	HCC_A64_STR_X0_X16
:HCC_MEM_MALLOC_READY
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&hcc_support_brk
	HCC_A64_SET_X0_FROM_X16
	DEREF_X0
	POP_X1
	PUSH_X0
	ADD_X0_X1_X0
	SET_X8_TO_SYS_BRK
	SYSCALL
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&hcc_support_brk
	HCC_A64_STR_X0_X16
	POP_X0
	RETURN

:FUNCTION_calloc
	MUL_X0_X1_X0
	PUSH_X0
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&FUNCTION_malloc
	BLR_X16
	HCC_A64_POP_X2
	SET_X1_TO_0
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&FUNCTION_memset
	BLR_X16
	RETURN

:FUNCTION_free
	RETURN

:hcc_support_brk
	'00' '00' '00' '00' '00' '00' '00' '00'

:__FUNCTION__
	'68' '63' '63' '00'
