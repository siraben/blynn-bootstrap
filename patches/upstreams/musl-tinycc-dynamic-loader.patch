+		if (IS_RELATIVE(rel[1], 0)) {
+			*rel_addr = base + rel[2];
+			continue;
+		}
+		if ((R_TYPE(rel[1]) == REL_GOT || R_TYPE(rel[1]) == REL_PLT
+		    || R_TYPE(rel[1]) == REL_SYMBOLIC)
+		    && R_SYM(rel[1]) && syms[R_SYM(rel[1])].st_shndx) {
+			*rel_addr = base + syms[R_SYM(rel[1])].st_value + rel[2];
+			continue;
+		}
 	}
 
+	rel = (void *)(base+dyn[DT_JMPREL]);
+	rel_size = dyn[DT_PLTRELSZ];
+	for (; rel_size; rel+=3, rel_size-=3*sizeof(size_t)) {
+		size_t *rel_addr = (void *)(base + rel[0]);
+		if ((R_TYPE(rel[1]) == REL_PLT || R_TYPE(rel[1]) == REL_GOT
+		    || R_TYPE(rel[1]) == REL_SYMBOLIC)
+		    && R_SYM(rel[1]) && syms[R_SYM(rel[1])].st_shndx) {
+			*rel_addr = base + syms[R_SYM(rel[1])].st_value + rel[2];
+			continue;
+		}
+	}
+
 	rel = (void *)(base+dyn[DT_RELR]);
