diff -ruN a/party_shims.c b/party_shims.c
--- /dev/null
+++ b/party_shims.c
@@ -0,0 +1,24 @@
+#include <stdio.h>
+
+static int nextCh, isAhead;
+
+int eof_shim(void) {
+  if (!isAhead) {
+    isAhead = 1;
+    nextCh = getchar();
+  }
+  return nextCh == -1;
+}
+
+void exit(int);
+
+void putchar_shim(int c) { putchar(c); }
+
+int getchar_shim(void) {
+  if (!isAhead) nextCh = getchar();
+  if (nextCh == -1) exit(1);
+  isAhead = 0;
+  return nextCh;
+}
+
+void errchar(int c) { fputc(c, stderr); }
+void errexit(void) { fputc('\n', stderr); }
